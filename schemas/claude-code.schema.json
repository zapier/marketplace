{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/zapier/marketplace/schemas/claude-code.schema.json",
  "title": "Claude Code marketplace manifest",
  "description": "Self-authored schema for .claude-plugin/marketplace.json. Anthropic references https://anthropic.com/claude-code/marketplace.schema.json from their canonical example but the URL returns 404; this schema is derived from the canonical anthropics/claude-plugins-official marketplace and the Claude Code plugin marketplace docs at https://code.claude.com/docs/en/plugin-marketplaces.",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Marketplace identifier in kebab-case"
    },
    "description": { "type": "string" },
    "owner": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "plugins": {
      "type": "array",
      "items": { "$ref": "#/definitions/plugin" }
    }
  },
  "definitions": {
    "plugin": {
      "type": "object",
      "required": ["name", "source"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "description": { "type": "string" },
        "version": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "homepage": { "type": "string", "format": "uri" },
        "repository": { "type": "string" },
        "license": { "type": "string" },
        "author": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "url": { "type": "string", "format": "uri" }
          }
        },
        "source": { "$ref": "#/definitions/source" }
      }
    },
    "source": {
      "oneOf": [
        { "type": "string", "description": "Local path within this repo" },
        {
          "type": "object",
          "required": ["source"],
          "properties": {
            "source": { "enum": ["git-subdir", "github"] },
            "url": { "type": "string", "format": "uri" },
            "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
            "path": { "type": "string" },
            "ref": { "type": "string" },
            "sha": { "type": "string", "pattern": "^[a-f0-9]{7,40}$" }
          }
        }
      ]
    }
  }
}
